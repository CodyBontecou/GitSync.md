# App Store Connect API key auth for fastlane
# Copy to fastlane/.env and fill values, or export these variables in your shell.

ASC_KEY_ID=YOUR_KEY_ID
# Required for Team API keys. Leave blank or unset for Individual API keys.
ASC_ISSUER_ID=YOUR_ISSUER_ID
ASC_KEY_FILEPATH=/absolute/path/to/AuthKey_YOUR_KEY_ID.p8
